# Copy this file to .env on api2.autisme.lu.
# Do not commit .env. It is ignored by .gitignore.

APP_ENV=production
PORT=3000
HOST=127.0.0.1
API_PUBLIC_URL=https://api2.autisme.lu

# Comma-separated frontend origins allowed to call this API in browsers.
CORS_ORIGINS=https://namnam.autisme.lu,http://localhost:3000

# Database. Fill these on the server only.
DB_HOST=your-db-host
DB_PORT=3306
DB_NAME=your-db-name
DB_USER=your-db-user
DB_PASSWORD=change-me-on-server
DB_CONNECTION_LIMIT=10
DB_SSL=false

# Security. Generate strong random values on the server.
AUTH_REQUIRED=true
SESSION_TTL_HOURS=12
PASSWORD_PEPPER=change-me-long-random-secret
INTERNAL_API_TOKEN=change-me-long-random-token
LEGACY_API_KEY=change-me-if-legacy-clients-need-x-api-key

# Optional operational controls.
LOG_LEVEL=info
MAX_UPLOAD_BYTES=10485760
UPLOAD_DIR=storage/uploads
REPORT_DIR=storage/reports
IMPORT_DIR=storage/imports
